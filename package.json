{
  "name": "jolly-wu",
  "version": "1.0.0",
  "description": "Enhance your video viewing experience by navigating easily with intuitive keyboard shortcuts and seamlessly resuming internet videos from where you left off.",
  "main": "background.js",
  "scripts": {
    "test": "playwright test",
    "test:animepahe": "playwright test --grep @animepahe",
    "publish": "node publish.js",
    "publish:dry-run": "node publish.js --dry-run",
    "publish:patch": "node publish.js --bump patch --publish",
    "publish:minor": "node publish.js --bump minor --publish",
    "publish:major": "node publish.js --bump major --publish"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2"
  }
}
